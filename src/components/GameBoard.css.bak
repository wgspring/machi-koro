/* ============ 全屏不滚动外壳 ============ */
html, body, #root { height: 100%; }
body { overflow: hidden; }

.board {
  height: 100vh;
  display: grid;
  grid-template-rows: auto 1fr;
  padding: 8px 12px 10px;
  gap: 8px;
  box-sizing: border-box;
}

/* ============ 顶栏 ============ */
.board__top {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 12px;
  border-bottom: 2px solid #e5e5e5;
  padding-bottom: 6px;
}
.board__top h1 {
  margin: 0;
  font-size: 1.15rem;
  white-space: nowrap;
}
.board__topActions { display: flex; gap: 6px; }
.board__topActions button {
  padding: 4px 10px;
  font-size: .85rem;
  border: 1px solid #c9cfd9;
  border-radius: 6px;
  background: #fff;
  cursor: pointer;
}
.board__topActions button:hover { background: #f0f3fa; }

/* PhaseHint(放进顶栏中间) */
.phase {
  background: #f6f8fb;
  border-left: 3px solid #4f7cff;
  padding: 4px 10px;
  border-radius: 4px;
  font-size: .85rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.phase--win {
  background: #fff8e0;
  border-color: #c89400;
  font-weight: 700;
  text-align: center;
}

/* ============ 主体三列 ============ */
.board__body {
  display: grid;
  grid-template-columns: 280px minmax(0, 1fr) 280px;
  gap: 10px;
  min-height: 0;     /* 让子元素能正确收缩 */
  overflow: hidden;
}
.board__side {
  min-height: 0;
  overflow: hidden;  /* 玩家面板自身管理内部滚动 */
}

/* 中央列:骰子(自适应) | 卡池(占据剩余,内部滚动) | 日志(固定低高度) */
.board__center {
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  gap: 8px;
  min-height: 0;
  min-width: 0;
}
.board__dice { min-height: 0; }
.board__market {
  min-height: 0;
  overflow: hidden; /* 内部 .market 会做 overflow-y:auto */
  display: flex;
}
.board__market > * { width: 100%; }
.board__log {
  min-height: 0;
  /* 日志保持紧凑高度,可内部滚动 */
  height: 130px;
}

/* ============ 弹窗(规则)保留可滚动 ============ */
.modal {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, .55);
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 24px 16px;
  overflow-y: auto;
  z-index: 10;
}
.modal__inner {
  position: relative;
  background: #fff;
  border-radius: 12px;
  max-width: 920px;
  width: 100%;
  max-height: calc(100vh - 48px);
  overflow-y: auto;
}
.modal__close {
  position: sticky;
  top: 8px;
  float: right;
  margin: 8px 8px 0;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: none;
  background: rgba(0, 0, 0, .12);
  cursor: pointer;
  font-size: 1rem;
  z-index: 1;
}

/* ============ 窄屏降级:纵向堆叠仍允许滚动 ============ */
@media (max-width: 980px) {
  body { overflow: auto; }
  .board { height: auto; min-height: 100vh; }
  .board__body {
    grid-template-columns: 1fr;
    overflow: visible;
  }
  .board__side, .board__center, .board__market { overflow: visible; }
  .board__log { height: auto; min-height: 160px; }
}

@media (prefers-color-scheme: dark) {
  .board__top { border-color: #333; }
  .board__topActions button { background: #2a2f3a; color: #eee; border-color: #444b58; }
  .phase { background: #1c2028; color: #eee; }
  .phase--win { background: #3a2e10; color: #ffe08a; }
  .modal__inner { background: #14171c; }
}
